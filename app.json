{
  "expo": {
    "name": "MyApp",
    "slug": "MyApp",
    "version": "1.0.0",

    "experiments": {
      "tsconfigPaths": true
    },

    "plugins": ["expo-router"],

    "orientation": "portrait",

    "userInterfaceStyle": "light",

    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {}
  }
}
